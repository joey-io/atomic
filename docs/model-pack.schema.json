{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atomic.dev/schemas/model-pack.v1.json",
  "title": "Atomic Model Pack",
  "type": "object",
  "required": ["atomic", "name", "models"],
  "additionalProperties": true,
  "properties": {
    "atomic": { "const": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "models": {
      "type": "array",
      "items": { "$ref": "#/$defs/model" }
    }
  },
  "$defs": {
    "model": {
      "type": "object",
      "required": ["name", "description"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "extends": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "description": { "type": "string", "minLength": 1 },
        "attributes": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/field" }
        },
        "relationships": { "type": "object" },
        "identity": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["fields"],
            "properties": {
              "fields": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
              "strength": { "enum": ["weak", "medium", "strong"] }
            }
          }
        },
        "observe": {
          "type": "object",
          "properties": {
            "positive": { "type": "array", "items": { "type": "string" } },
            "negative": { "type": "array", "items": { "type": "string" } },
            "instructions": { "type": "string" }
          }
        },
        "presentation": { "type": "object" }
      }
    },
    "field": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": true,
      "properties": {
        "kind": {
          "enum": ["text", "longtext", "email", "url", "uuid", "integer", "number", "boolean", "datetime", "enum", "ref", "list", "map", "json"]
        },
        "description": { "type": "string" },
        "required": { "type": "boolean" },
        "to": { "type": "string" },
        "items": { "$ref": "#/$defs/field" },
        "values": { "type": "array" }
      }
    }
  }
}
